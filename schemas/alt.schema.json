{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acc0mplish/aesthete/schemas/alt.schema.json",
  "title": "Abstract Layout Tree",
  "description": "Domain-agnostic geometry: every visual object is a node with a bbox. The source of truth for all measurement skills.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "diagram_type", "meta", "nodes"],
  "properties": {
    "schema_version": { "const": 1 },
    "diagram_type": { "const": "layout" },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "canvas"],
      "properties": {
        "title": { "type": "string" },
        "canvas": {
          "type": "object",
          "additionalProperties": false,
          "required": ["w", "h"],
          "properties": {
            "w": { "type": "number", "minimum": 0 },
            "h": { "type": "number", "minimum": 0 }
          }
        },
        "source": { "enum": ["svg", "html", "pptx", "docx", "xlsx", "image", "ooxml", "abstract", "synthetic-ground-truth"] },
        "output": { "type": "string" },
        "note": { "type": "string" },
        "design": { "type": "object" }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "bbox"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "label": { "type": "string" },
          "category": { "type": "string" },
          "kind": { "$ref": "common.schema.json#/$defs/nodeKind" },
          "shape": { "$ref": "common.schema.json#/$defs/nodeShape" },
          "bbox": { "$ref": "common.schema.json#/$defs/bbox" },
          "style": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "fontSize": { "type": "number", "minimum": 0 },
              "luminance": { "type": "number", "minimum": 0, "maximum": 1 },
              "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
              "color": { "type": "string" },
              "bg": { "type": "string" },
              "filled": { "type": "boolean", "description": "false for stroke-only/outline elements (e.g. lucide fill=none) — used to skip stroke–stroke crossing 'collisions' in icons" },
              "role": { "$ref": "common.schema.json#/$defs/role" }
            }
          }
        }
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "members"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "members": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "common.schema.json#/$defs/id" }
          },
          "label": { "type": "string" }
        }
      }
    }
  }
}
